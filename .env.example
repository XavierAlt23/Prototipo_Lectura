# .env.example

# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=True
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://cyberbullying_user:password@localhost:5432/cyberbullying_detection
DATABASE_ECHO=False

# Model Configuration
MODEL_CHECKPOINT_DIR=./ml/checkpoints
MODEL_CACHE_DIR=./.cache

# ML Configuration
DEVICE=cpu  # or cuda
RANDOM_SEED=42

# API Keys (si aplica)
API_KEY=your_api_key_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:8000/api/v1
